#!/usr/bin/env python3
import os
import sys
import zipfile


def main() -> int:
    destination = "."
    zip_path = None
    args = sys.argv[1:]
    index = 0

    while index < len(args):
        arg = args[index]
        if arg == "-d":
            index += 1
            if index >= len(args):
                print("unzip wrapper: missing destination after -d", file=sys.stderr)
                return 2
            destination = args[index]
        elif arg.startswith("-"):
            # Flutter calls unzip with flags like -o and -q. Python's zipfile
            # overwrites by default, and this wrapper stays quiet unless failing.
            pass
        elif zip_path is None:
            zip_path = arg
        else:
            print(f"unzip wrapper: unsupported argument {arg}", file=sys.stderr)
            return 2
        index += 1

    if zip_path is None:
        print("unzip wrapper: missing zip file", file=sys.stderr)
        return 2

    os.makedirs(destination, exist_ok=True)
    with zipfile.ZipFile(zip_path) as archive:
        archive.extractall(destination)

    return 0


if __name__ == "__main__":
    raise SystemExit(main())
